set.seed(13)
library(dslabs)
dt <- as.data.table(brca$x)
dt[, y := brca$y == "M" ]
dt <- dt[sample(1:nrow(dt))]
train_dt<-dt[1:341]
test_dt<-dt[342:nrow(dt)]
logreg_1 <-glm(y~fractal_dim_mean, data=train_dt, family = "binomial")
test_dt[, preds := predict(logreg_1)]
View(test_dt)
View(test_dt)
test_dt<-test_dt[,fractal_dim_mean ]
test_dt[, preds := predict(logreg_1)]
tbl <- matrix(c(85,39,26,90),nrow=2,ncol=2)
row.names(tbl) <- c("Vaccinated","Not Vaccinated")
colnames(tbl) <- c("Not Infected","Infected")
tst <- fisher.test(tbl,  alternative = "exist association")
tst <- fisher.test(tbl,  alternative = "greater")
tst
tst$p.value
