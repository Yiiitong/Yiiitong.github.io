library(caret)
k <- 7
fitControl <- trainControl(method = "cv",
number = k,
)
lr_fit <- train(
oleic~eicosenoic+arachidic+linolenic,
data = dt,
method = "lm",
trControl = fitControl,
metric = "ROC",
)
