library(ggplot2)
library(data.table)
library(magrittr)
library(tidyr)
library(dplyr)
library(patchwork) # optional, makes plots nicer
library(cowplot)
iris_dt <- as.data.table(iris)
base_model <- lm(Sepal.Width - Sepal.Length, iris_dt)
summary(base_model)
iris_dt
base_model <- lm(Sepal.Width - Sepal.Length, iris_dt)
base_model <- lm(Sepal.Width ~ Sepal.Length, iris_dt)
summary(base_model)
diff_intercept_model <- lm(Sepal.Width ~ Sepal.Length +Species, iris_dt)
summary(diff_intercept_model)
# Y = X.Beta
model.matrix(diff_intercept_model)
diff_intercept_slope_model <- lm(Sepal.Width ~ Sepal.Length * Species, iris_dt)
summary(diff_intercept_slope_model)
mat <- model.matrix(diff_intercept_slope_model)
Vie(mat)
View(mat)
mat#
iris_dt[, base_preds := predict(base_model)]
iris_dt[, diff_intercept_preds := predict(diff_intercept_model)]
iris_dt[, diff_intercept_slope_preds := predict(diff_intercept_slope_model)]
ggplot(iris_dt, aes(Sepal.Length, Sepal.Width)) +
geom_point(aes(color = Species)) +
geom_line(aes(Sepal.Length, base_preds))
ggplot(iris_dt, aes(Sepal.Length, Sepal.Width)) +
geom_point(aes(color = Species)) +
geom_line(aes(Sepal.Length, base_preds)) +
facet_wrap(~Species)
ggplot(iris_dt, aes(Sepal.Length, Sepal.Width, color=Species)) +
geom_point() +
geom_line(aes(Sepal.Length, diff_intercept_preds)) +
facet_wrap(~Species)
ggplot(iris_dt, aes(Sepal.Length, Sepal.Width, color=Species)) +
geom_point() +
geom_line(aes(Sepal.Length, diff_intercept_slope_preds)) +
facet_wrap(~Species)
# 4
anova(base_model, diff_intercept_model)
anove(diff_intercept_model, diff_intercept_slope_model)
anova(diff_intercept_model, diff_intercept_slope_model)
ggplot(iris_dt, aes(Sepal.Length, Sepal.Width)) +
geom_point(color=Species) +
geom_line(aes(Sepal.Length, diff_intercept_slope_preds)) +
facet_wrap(~Species)
ggplot(iris_dt, aes(Sepal.Length, Sepal.Width)) +
geom_point(aes(color=Species)) +
geom_line(aes(Sepal.Length, diff_intercept_slope_preds)) +
facet_wrap(~Species)
